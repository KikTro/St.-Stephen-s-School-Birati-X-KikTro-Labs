rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user matches document owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
    }

    // Rules for Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.author.uid == request.auth.uid;
      
      // Allow author to delete or edit post fully, or others to increment/change reactions arrays
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.author.uid || 
        (
          // Restrict updates to only modification of reaction arrays
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['heartedBy', 'upvotedBy', 'downvotedBy'])
        )
      );
      
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.author.uid;

      // Rules for comments subcollection
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.author.uid == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.author.uid == request.auth.uid;
      }
    }
  }
}
